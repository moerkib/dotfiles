# Prüfen, ob 'codium' bereits direkt als Befehl verfügbar ist
if ! command -v codium &> /dev/null; then
    
    # Wenn nicht, prüfen, ob es als Flatpak installiert ist
    # VSCodium nutzt im Flatpak-Universum die ID 'com.vscodium.codium'
    if command -v flatpak &> /dev/null && flatpak list &> /dev/null --columns=application | grep -q "com.vscodium.codium"; then
        
        # Alias einrichten, damit sich das Flatpak wie die native CLI verhält
        alias codium="flatpak run com.vscodium.codium"
        
    fi
fi

