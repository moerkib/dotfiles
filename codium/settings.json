{
    // --- TELEMETRIE & "NACH HAUSE TELEFONIEREN" DEAKTIVIEREN ---
    "telemetry.telemetryLevel": "off",
    "telemetry.enableTelemetry": false,
    "telemetry.enableCrashReporter": false,
    "workbench.enableExperiments": false,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "update.mode": "none",
    "extensions.autoCheckUpdates": false,
    "extensions.autoUpdate": false,
    "extensions.showRecommendationsOnlyOnDemand": true,
    // --- WORKSPACE TRUST ("Diesem Ordner vertrauen") ABSCHALTEN ---
    "security.workspace.trust.enabled": false,
    "security.workspace.trust.startupPrompt": "never",
    "security.workspace.trust.emptyWindowDelayedPrompt": false,
    // --- AUTO-VERVOLLSTÄNDIGUNG / INTELLISENSE NUR BEI STRG+LEERTASTE ---
    "editor.quickSuggestions": {
        "other": "off",
        "comments": "off",
        "strings": "off"
    },
    "editor.suggestOnTriggerCharacters": false,
    "editor.parameterHints.enabled": false,
    // --- AUTOMATISCH SPEICHERN & FORMATIEREN BEI TAB-WECHSEL ---
    "files.autoSave": "onFocusChange",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "yaml.schemas": {
        "file:///home/markus/.vscode-oss/extensions/continue.continue-1.2.22-linux-x64/config-yaml-schema.json": [
            ".continue/**/*.yaml"
        ]
    },
    "workbench.colorTheme": "acme",
    "editor.minimap.enabled": false,
    "go.testFlags": [
        "-v"
    ],
    "git.enableSmartCommit": true
}