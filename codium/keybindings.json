[
    // Zeilenkommentar umschalten mit Alt + Y
    {
        "key": "alt+y",
        "command": "editor.action.commentLine",
        "when": "editorTextFocus && !editorReadonly"
    },
    // Standard-Shortcut für "Zeile löschen" (Strg+Shift+K) auf Strg + Y umbiegen
    {
        "key": "ctrl+y",
        "command": "editor.action.deleteLines",
        "when": "editorTextFocus && !editorReadonly"
    },
    // Verhindert, dass Strg + Y weiterhin das standardmäßige "Redo" (Wiederholen) ausführt
    {
        "key": "ctrl+y",
        "command": "-redo"
    }
]